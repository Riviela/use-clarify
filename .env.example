# ─────────────────────────────────────────────────────────
#  Clarify — Environment Variables Template
#  Copy this file to `.env.local` and fill in real values.
#  NEVER commit `.env.local` to version control.
# ─────────────────────────────────────────────────────────

# ── App ──
# Your production domain (no trailing slash). Used for OAuth redirects, checkout return URLs, etc.
NEXT_PUBLIC_APP_URL=https://use-clarify.com

# ── Supabase ──
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (server-only, used by webhook to bypass RLS)
# DANGER: Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq AI ──
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Lemon Squeezy (Payments) ──
# Use LIVE mode keys for production, TEST mode for development.
# Get from: Lemon Squeezy Dashboard → Settings → API
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret

# Variant IDs from your Clarify Pro product (LIVE mode)
# Monthly checkout URL:
#   https://clarifyapp.lemonsqueezy.com/checkout/buy/fd17bea8-b979-4c2c-bc03-5f0a01dbd956?enabled=1510976
# Yearly checkout URL:
#   https://clarifyapp.lemonsqueezy.com/checkout/buy/2595663d-dd13-4d9a-b296-036eda3f4560?enabled=1510977
NEXT_PUBLIC_LEMON_VARIANT_MONTHLY=1510976
NEXT_PUBLIC_LEMON_VARIANT_YEARLY=1510977
